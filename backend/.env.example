# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Mini App URL
MINI_APP_URL=https://your-domain.com

# Роли: номера телефонов (через запятую). Формат свободный — сравниваются только цифры.
BOSHLIQ_PHONES=998901234567
ADMIN_PHONES=998907654321

# Database — PostgreSQL (production)
# Формат: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/telegram_app
# Для локальной разработки можно временно использовать SQLite:
# DATABASE_URL=sqlite:///./tasks.db

# Secret
SECRET_KEY=your-secret-key-change-in-production

# Максимальный возраст Telegram initData в секундах (по умолчанию 24 часа)
INIT_DATA_MAX_AGE=86400

# Разрешённые источники для CORS (через запятую). НЕ используйте "*" в production.
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000

# ---------------------------------------------------------------------------
# S3-совместимое объектное хранилище файлов отчётов (production)
# ---------------------------------------------------------------------------
# Если заданы S3_BUCKET + S3_ACCESS_KEY + S3_SECRET_KEY — файлы хранятся в S3.
# Если оставить пустыми — файлы сохраняются локально в папке uploads (только разработка).
# Работает с AWS S3, MinIO, Cloudflare R2, Yandex Object Storage и т.п.
S3_ENDPOINT=                 # напр. https://s3.amazonaws.com (для AWS можно оставить пустым)
S3_BUCKET=                   # имя бакета
S3_ACCESS_KEY=               # ключ доступа
S3_SECRET_KEY=               # секретный ключ
S3_REGION=us-east-1          # регион
S3_PREFIX=reports            # папка (префикс) внутри бакета
S3_URL_EXPIRE=3600           # срок жизни ссылки на скачивание, сек (по умолчанию 1 час)

# ---------------------------------------------------------------------------
# Ограничения на загружаемые файлы
# ---------------------------------------------------------------------------
MAX_VIDEO_SIZE_MB=500
MAX_IMAGE_SIZE_MB=20
MAX_AUDIO_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=100

# Допустимые MIME-типы (через запятую). Можно переопределить при необходимости.
ALLOWED_VIDEO_MIME=video/mp4,video/quicktime,video/x-msvideo,video/x-matroska,video/webm,video/3gpp
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/heic,image/heif,image/gif
ALLOWED_AUDIO_MIME=audio/mpeg,audio/mp4,audio/aac,audio/ogg,audio/wav,audio/x-wav,audio/webm,audio/3gpp
ALLOWED_DOCUMENT_MIME=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain
