# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=8654953686:AAEEr1TyZLGtYYFovRC3NHezxdlez08r9qo

# Mini App URL (URL вашего frontend)
MINI_APP_URL=https://unevolved-alphonse-knockless.ngrok-free.dev

# Роли: укажите номера телефонов (через запятую). Сравниваются только цифры.
# Boshliq (владелец) — можно указать несколько через запятую
BOSHLIQ_PHONES=998915973905

# Admin (помощник владельца) — можно указать несколько через запятую
ADMIN_PHONES=15792644140

# Database URL — PostgreSQL (production).
# Формат: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/telegram_app
# Для локальной разработки можно временно использовать SQLite:
DATABASE_URL=sqlite:///./tasks.db

# Секретный ключ для JWT (сгенерируйте свой)
SECRET_KEY=your-secret-key-change-in-production

# Максимальный возраст Telegram initData в секундах (по умолчанию 24 часа)
INIT_DATA_MAX_AGE=86400

# Разрешённые источники для CORS (через запятую). НЕ используйте "*" в production.
ALLOWED_ORIGINS=https://unevolved-alphonse-knockless.ngrok-free.dev,http://localhost:3000

# ---------------------------------------------------------------------------
# S3-совместимое объектное хранилище файлов отчётов (production)
# ---------------------------------------------------------------------------
# Заполните для хранения файлов в S3. Если оставить пустыми — файлы хранятся
# локально в папке uploads (подходит только для разработки).
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PREFIX=reports
S3_URL_EXPIRE=3600

# ---------------------------------------------------------------------------
# Ограничения на загружаемые файлы (размер в МБ)
# ---------------------------------------------------------------------------
MAX_VIDEO_SIZE_MB=500
MAX_IMAGE_SIZE_MB=20
MAX_AUDIO_SIZE_MB=50
MAX_DOCUMENT_SIZE_MB=100
